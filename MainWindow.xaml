<Window x:Class="Bcgame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:local="clr-namespace:Bcgame"
        mc:Ignorable="d"
        Style="{StaticResource WindowStyled}" Title="Bcgame 10.0" Height="683" Width="1470" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded" Closing="Window_Closing">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="1" Height="30" BorderBrush="#000" BorderThickness="0" Background="#111" Visibility="Collapsed">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource ToolBar}" Margin="0,0,10,0" Name="clearLogButton" Click="clearLogButton_Click">Очистить лог</Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Button x:Name="addProfile" Click="addProfile_Click" HorizontalAlignment="Left">Добавить профиль</Button>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <CheckBox Name="isTest" Checked="isTest_Checked" Unchecked="isTest_Checked" VerticalAlignment="Center">Тестовый режим (не делать ставки)</CheckBox>
                <CheckBox Name="isReload" Checked="isReload_Checked" Unchecked="isReload_Checked" VerticalAlignment="Center">Перезагружать браузеры</CheckBox>
                <TextBox x:Name="reloadMins" Width="50" TextChanged="reloadMins_TextChanged"></TextBox>
            </StackPanel>
            <ListBox Grid.Row="1" Name="profiles" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.CanContentScroll="False">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid VerticalAlignment="Top">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Button Style="{StaticResource ToolBar}" Tag="{Binding Path=id}" Margin="10,0,10,0" Name="startProfile" Click="startProfile_Click">
                                        <Image>
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Setter Property="Source" Value="Images/start.png"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Path=started}" Value="True">
                                                            <Setter Property="Source" Value="Images/stop.png"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                    </Button>
                                </StackPanel>
                                <TextBlock Grid.Column="1">ID профиля:</TextBlock>
                                <TextBox Grid.Column="2" Text="{Binding Path=id, Mode=TwoWay}" VerticalAlignment="Center" Width="85"></TextBox>
                                <ComboBox Grid.Column="3" SelectedIndex="{Binding Path=type, Mode=TwoWay}" Width="150" Name="type" SelectionChanged="type_SelectionChanged">
                                    <ComboBoxItem>Оригинал</ComboBoxItem>
                                    <ComboBoxItem>Мартингейл</ComboBoxItem>
                                    <ComboBoxItem>Пенальти фора</ComboBoxItem>
                                    <ComboBoxItem>FULL-LIMIT</ComboBoxItem>
                                </ComboBox>
                            </Grid>
                            <Grid Grid.Column="1" Visibility="{Binding Path=grid1}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*" />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock>Рандомное время (сек):</TextBlock>
                                <StackPanel Grid.Row="1" Orientation="Horizontal">
                                    <TextBlock>от</TextBlock>
                                    <TextBox Width="30" Text="{Binding Path=randomSecs1, Mode=TwoWay}"></TextBox>
                                    <TextBlock>до</TextBlock>
                                    <TextBox Width="30" Text="{Binding Path=randomSecs2, Mode=TwoWay}"></TextBox>
                                </StackPanel>
                                <TextBlock Grid.Column="1">Исход:</TextBlock>
                                <ComboBox Grid.Row="1" Grid.Column="1" SelectedIndex="{Binding Path=market, Mode=TwoWay}">
                                    <ComboBoxItem>меньше 6.5</ComboBoxItem>
                                    <ComboBoxItem>больше 5.5</ComboBoxItem>
                                </ComboBox>
                                <TextBlock Grid.Column="2">Сумма ставки, $:</TextBlock>
                                <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding Path=amount1S, Mode=TwoWay}"></TextBox>
                                <TextBlock Grid.Column="3">Количество событий:</TextBlock>
                                <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding Path=eventsCount, Mode=TwoWay}"></TextBox>
                                <TextBlock Grid.Column="4">Перезагрузка, мин:</TextBlock>
                                <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding Path=reload, Mode=TwoWay}"></TextBox>
                                <TextBlock Grid.Column="5">Счетчик событий:</TextBlock>
                                <TextBox Grid.Row="1" Grid.Column="5" Text="{Binding Path=eventsCurrentCount}" IsEnabled="False"></TextBox>
                                <Button Grid.Row="1" Grid.Column="6" Style="{StaticResource ToolBar}" Tag="{Binding Path=id}" x:Name="eventsCurrentCountReset" Click="eventsCurrentCountReset_Click" VerticalAlignment="Center" HorizontalAlignment="Left">Сбросить</Button>
                            </Grid>
                            <Grid Grid.Column="1" Visibility="{Binding Path=grid2}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="1.5*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock>Кол-во ставок:</TextBlock>
                                <TextBox Grid.Row="1" Text="{Binding Path=betsCount, Mode=TwoWay}"></TextBox>
                                <TextBlock Grid.Column="1">Исход:</TextBlock>
                                <ComboBox Grid.Row="1" Grid.Column="1" SelectedIndex="{Binding Path=marketM, Mode=TwoWay}">
                                    <ComboBoxItem>больше 6.5</ComboBoxItem>
                                    <ComboBoxItem>меньше 5.5</ComboBoxItem>
                                </ComboBox>
                                <TextBlock Grid.Column="2">Сумма ставки, $:</TextBlock>
                                <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding Path=amountS, Mode=TwoWay}"></TextBox>
                                <TextBlock Grid.Column="3">Макс. сумма:</TextBlock>
                                <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding Path=limitS, Mode=TwoWay}"></TextBox>
                                <TextBlock Grid.Column="4">Общая сумма:</TextBlock>
                                <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding Path=sumS}" IsEnabled="False"></TextBox>
                                <CheckBox Grid.Column="5" IsChecked="{Binding Path=miss2odds, Mode=TwoWay}" VerticalAlignment="Center">Пропускать кэф ниже 2</CheckBox>
                                <Button Grid.Row="1" Grid.Column="5" Style="{StaticResource ToolBar}" Tag="{Binding Path=id}" x:Name="betsReset" Click="betsReset_Click" HorizontalAlignment="Left">Сбросить</Button>
                                <CheckBox Grid.Column="6" IsChecked="{Binding Path=toggle}">Переключить на Пенальти фора при балансе:</CheckBox>
                                <TextBox Grid.Row="1" Grid.Column="6" Text="{Binding Path=toggleBalanceS}"></TextBox>
                            </Grid>
                            <Grid Grid.Column="1" Visibility="{Binding Path=grid3}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="1.5*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock>Нижний кэф:</TextBlock>
                                <TextBox Grid.Row="1" Text="{Binding Path=downOdd, Mode=TwoWay}"></TextBox>
                                <TextBlock Grid.Column="1">Сумма ставки, $:</TextBlock>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Path=amount2S, Mode=TwoWay}"></TextBox>
                                <TextBlock Grid.Column="2">Макс. сумма:</TextBlock>
                                <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding Path=limitS1, Mode=TwoWay}"></TextBox>
                                <TextBlock Grid.Column="3">Общая сумма:</TextBlock>
                                <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding Path=sumS1}" IsEnabled="False"></TextBox>
                                <TextBlock Grid.Column="4">Баланс:</TextBlock>
                                <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding Path=balanceS}" IsEnabled="False"></TextBox>
                                <Button Grid.Row="1" Grid.Column="5" Style="{StaticResource ToolBar}" Tag="{Binding Path=id}" x:Name="penaltyReset" Click="penaltyReset_Click" HorizontalAlignment="Left">Сбросить</Button>
                            </Grid>
                            <Grid Grid.Column="1" Visibility="{Binding Path=grid_surebet}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock>Ссылка:</TextBlock>
                                <TextBox Grid.Column="1" Grid.ColumnSpan="6" Text="{Binding Path=link_surebet, Mode=TwoWay}"></TextBox>
                                <ComboBox Grid.Column="7" SelectedIndex="{Binding Path=type_surebet, Mode=TwoWay}" Width="100">
                                    <ComboBoxItem>FULL</ComboBoxItem>
                                    <ComboBoxItem>LIMIT</ComboBoxItem>
                                </ComboBox>
                                <CheckBox Grid.Column="8" IsChecked="{Binding Path=fifa_surebet, Mode=TwoWay}" VerticalAlignment="Center">FIFA</CheckBox>
                                <TextBlock Grid.Row="1">Макс. сумма:</TextBlock>
                                <TextBox Grid.Row="2" Text="{Binding Path=limitS_surebet, Mode=TwoWay}"></TextBox>
                                <TextBlock Grid.Row="1" Grid.Column="1">Задержка, сек:</TextBlock>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Path=delay_surebet, Mode=TwoWay}"></TextBox>
                                <TextBlock Grid.Row="1" Grid.Column="2">Задержка между ставками, сек:</TextBlock>
                                <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding Path=delay_between_bets_surebet, Mode=TwoWay}"></TextBox>
                                <TextBlock Grid.Row="1" Grid.Column="3">Сумма ставки:</TextBlock>
                                <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding Path=amountS_surebet, Mode=TwoWay}"></TextBox>
                                <TextBlock Grid.Row="1" Grid.Column="4">Номер матча:</TextBlock>
                                <TextBox Grid.Row="2" Grid.Column="4" Text="{Binding Path=index_surebet, Mode=TwoWay}"></TextBox>
                                <TextBlock Grid.Row="1" Grid.Column="5">Мин. доходность:</TextBlock>
                                <TextBox Grid.Row="2" Grid.Column="5" Text="{Binding Path=minprofit_surebet, Mode=TwoWay}"></TextBox>
                                <TextBlock Grid.Row="1" Grid.Column="6">Общая сумма:</TextBlock>
                                <TextBox Grid.Row="2" Grid.Column="6" Text="{Binding Path=sumS_surebet}" IsEnabled="False"></TextBox>
                                <TextBlock Grid.Row="1" Grid.Column="7">Баланс:</TextBlock>
                                <TextBox Grid.Row="2" Grid.Column="7" Text="{Binding Path=balanceS}" IsEnabled="False"></TextBox>
                                <Button Grid.Row="2" Grid.Column="8" Style="{StaticResource ToolBar}" Tag="{Binding Path=id}" x:Name="surebetReset" Click="surebetReset_Click" HorizontalAlignment="Left">Сбросить</Button>
                            </Grid>
                            <Grid Grid.Column="2" VerticalAlignment="Top">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding Path=comment, Mode=TwoWay}" Width="70" VerticalAlignment="Center"></TextBox>
                                <Button Grid.Column="1" Style="{StaticResource ToolBar}" Tag="{Binding Path=id}" x:Name="deleteProfile" Click="deleteProfile_Click">Удалить</Button>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <GridSplitter Grid.Row="3" HorizontalAlignment="Stretch" Height="2" Background="#555"></GridSplitter>
        <RichTextBox Grid.Row="4" Name="log" AcceptsReturn="True" FontSize="12" IsReadOnly="True" FontFamily="Consolas"></RichTextBox>
    </Grid>
</Window>
